# ── HuggingFace ───────────────────────────────────────────────────────────────
# Required for access to gated models (e.g. Llama 3.1)
HF_TOKEN=your_huggingface_token_here

# ── vLLM backend (Burger Agent) ───────────────────────────────────────────────
VLLM_MODEL=hosted_vllm/meta-llama/Llama-3.1-8B-Instruct
OPENAI_API_BASE=http://localhost:8088/v1

# ── Ollama backend (Pizza Agent + Root Agent) ─────────────────────────────────
OLLAMA_MODEL=ollama_chat/llama3.1:latest
OLLAMA_BASE_URL=http://localhost:11434

# ── Burger Seller Agent ───────────────────────────────────────────────────────
BURGER_SERVER_HOST=0.0.0.0
BURGER_SERVER_PORT=10001
BURGER_AUTH_USERNAME=burgeruser123
BURGER_AUTH_PASSWORD=burgerpass123
BURGER_SELLER_AGENT_URL=http://localhost:10001
BURGER_SELLER_AGENT_AUTH=burgeruser123:burgerpass123

# ── Pizza Seller Agent ────────────────────────────────────────────────────────
PIZZA_SERVER_HOST=0.0.0.0
PIZZA_SERVER_PORT=10000
API_KEY=pizza123
PIZZA_SELLER_AGENT_URL=http://localhost:10000
PIZZA_SELLER_AGENT_AUTH=pizza123

# ── Gradio UI ─────────────────────────────────────────────────────────────────
UI_PORT=8087
